{
  "expo": {
    "name": "SiteSync",
    "slug": "sitesync",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#111827"
    },
    "ios": {
      "bundleIdentifier": "com.sitesync.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SiteSync uses your camera for site documentation",
        "NSLocationWhenInUseUsageDescription": "SiteSync tags photos with GPS coordinates"
      }
    },
    "android": {
      "package": "com.sitesync.app",
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": ["expo-router", "expo-camera", "expo-location"]
  }
}
