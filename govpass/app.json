{
  "expo": {
    "name": "GovPass",
    "slug": "govpass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "govpass",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a56db"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.govpass.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to securely access your document vault",
        "NSCameraUsageDescription": "Scan identity documents for automatic data extraction"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a56db"
      },
      "package": "com.govpass.app",
      "permissions": ["android.permission.CAMERA", "android.permission.USE_BIOMETRIC"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-camera",
        { "cameraPermission": "Allow GovPass to access your camera to scan documents" }
      ],
      [
        "expo-notifications",
        { "sounds": [] }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}