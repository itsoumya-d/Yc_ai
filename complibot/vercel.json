{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@complibot_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@complibot_supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@complibot_supabase_service_role_key",
    "OPENAI_API_KEY": "@complibot_openai_api_key",
    "STRIPE_SECRET_KEY": "@complibot_stripe_secret_key",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@complibot_stripe_publishable_key",
    "NEXT_PUBLIC_APP_URL": "@complibot_app_url"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ]
}
