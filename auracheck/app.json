{
  "expo": {
    "name": "AuraCheck",
    "slug": "auracheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "auracheck",
    "plugins": [
      "expo-router",
      "expo-camera",
      ["expo-notifications", {"sounds": ["./assets/notification.wav"]}]
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.auracheck.app",
      "infoPlist": {
        "NSCameraUsageDescription": "AuraCheck uses your camera to capture skin photos for AI analysis.",
        "NSPhotoLibraryUsageDescription": "AuraCheck needs access to your photos to analyze existing skin images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#e11d48"
      },
      "package": "com.auracheck.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    }
  }
}
