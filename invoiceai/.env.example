# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI (for AI invoice drafting)
OPENAI_API_KEY=your_openai_api_key

# Paddle Billing (replaces Stripe — works for Indian businesses globally)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_...
PADDLE_API_KEY=pdl_live_...
PADDLE_WEBHOOK_SECRET=pdlwh_...
PADDLE_PRICE_PRO_MONTHLY=pri_01...
PADDLE_PRICE_PRO_ANNUAL=pri_01...
PADDLE_PRICE_BUSINESS_MONTHLY=pri_01...
PADDLE_PRICE_BUSINESS_ANNUAL=pri_01...

# SendGrid (for email delivery)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@invoiceai.app
FROM_NAME=invoiceai

# App URL (used for OAuth redirects)
# Development: http://localhost:3000 | Production: https://invoiceai.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_ORG=your-org
SENTRY_PROJECT=invoiceai

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Supabase PgBouncer connection pooler (Transaction mode)
# Get from: Supabase Dashboard → Settings → Database → Connection pooling → Transaction mode
# Use this URL in any direct pg/Prisma connections for connection pooling
DATABASE_POOLER_URL=postgresql://postgres.your-project:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
