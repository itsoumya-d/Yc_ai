{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 9 * * *"
    }
  ],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@invoiceai_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@invoiceai_supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@invoiceai_supabase_service_role_key",
    "OPENAI_API_KEY": "@invoiceai_openai_api_key",
    "STRIPE_SECRET_KEY": "@invoiceai_stripe_secret_key",
    "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": "@invoiceai_stripe_publishable_key",
    "STRIPE_WEBHOOK_SECRET": "@invoiceai_stripe_webhook_secret",
    "SENDGRID_API_KEY": "@invoiceai_sendgrid_api_key",
    "CRON_SECRET": "@invoiceai_cron_secret",
    "NEXT_PUBLIC_APP_URL": "@invoiceai_app_url"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    },
    {
      "source": "/pay/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
