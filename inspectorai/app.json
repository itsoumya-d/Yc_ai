{
  "expo": {
    "name": "InspectorAI",
    "slug": "inspectorai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1B2A4A"
    },
    "ios": {
      "bundleIdentifier": "com.inspectorai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "InspectorAI uses your camera to capture property damage for AI analysis"
      }
    },
    "android": {
      "package": "com.inspectorai.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "plugins": ["expo-router", "expo-camera"]
  }
}
