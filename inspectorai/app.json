{
  "expo": {
    "name": "InspectorAI",
    "slug": "inspectorai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": { "backgroundColor": "#1E40AF" },
    "ios": {
      "bundleIdentifier": "com.inspectorai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "InspectorAI captures photos of property damage.",
        "NSPhotoLibraryUsageDescription": "InspectorAI reads photos from your library."
      }
    },
    "android": { "package": "com.inspectorai.app", "permissions": ["CAMERA"] },
    "plugins": ["expo-router", "expo-camera", "expo-sqlite"],
    "scheme": "inspectorai",
    "experiments": { "typedRoutes": true }
  }
}
