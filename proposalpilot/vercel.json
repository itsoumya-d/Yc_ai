{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@proposalpilot_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@proposalpilot_supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@proposalpilot_supabase_service_role_key",
    "OPENAI_API_KEY": "@proposalpilot_openai_api_key",
    "SENDGRID_API_KEY": "@proposalpilot_sendgrid_api_key",
    "NEXT_PUBLIC_APP_URL": "@proposalpilot_app_url"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
