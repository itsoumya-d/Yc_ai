{
  "expo": {
    "name": "ComplianceSnap",
    "slug": "compliancesnap-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "compliancesnap",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D3436"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "ComplianceSnap uses your camera to capture inspection photos.",
        "NSMicrophoneUsageDescription": "ComplianceSnap uses your microphone for voice annotations.",
        "NSLocationWhenInUseUsageDescription": "ComplianceSnap uses your location to tag inspection sites."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2D3436"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-location"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
