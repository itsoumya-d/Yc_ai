{
  "expo": {
    "name": "Claimback",
    "slug": "claimback",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "claimback",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0fdf4"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.claimback.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Claimback uses the camera to scan your bills",
        "NSPhotoLibraryUsageDescription": "Claimback needs access to your photos to import bills"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f0fdf4"
      },
      "package": "com.claimback.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Claimback needs access to your photos to import bills."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
